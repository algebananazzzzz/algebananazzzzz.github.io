---
import Base from '@/layouts/Base.astro';
import MilkyWay from '@/components/island/MilkyWay';
import MilkyWayStreak from '@/components/island/MilkyWayStreak';
import manifest from '@/content/wiki-manifest.json';
import type { WikiManifest, WikiPage } from '@/types/wiki';

const wiki = manifest as WikiManifest;
const { pages, topics, meta } = wiki;

const total = pages.length;
const totalLinks = pages.reduce((s: number, p: WikiPage) => s + p.links.length, 0);

const recent = [...pages]
  .sort((a: WikiPage, b: WikiPage) => b.date.localeCompare(a.date))
  .slice(0, 6);

const topicColorById: Record<string, string> = Object.fromEntries(
  topics.map((t) => [t.id, t.dotColor]),
);

const topicLabelById: Record<string, string> = Object.fromEntries(
  topics.map((t) => [t.id, t.label]),
);

const buildDate = Date.now();
function noteMagnitude(n: WikiPage): number {
  const linkBonus = n.links.length * -0.35;
  let ageDays = 0;
  if (n.date && /^\d{4}-\d{2}-\d{2}/.test(n.date)) {
    ageDays = Math.max(0, (buildDate - Date.parse(n.date)) / 86400000);
  }
  const agePenalty = Math.log(Math.max(1, ageDays)) * 0.45;
  return -2.0 + linkBonus + agePenalty;
}
function formatMagnitude(m: number): string {
  const sign = m >= 0 ? '+' : '';
  return `M ${sign}${m.toFixed(1)}`;
}
---

<Base
  title="milky way"
  description="a sky of half-formed thoughts."
  accent="cosmic"
  mwPage={true}
>
  <div class="mw-page-bg" aria-hidden="true">
    <MilkyWayStreak client:only="react" />
  </div>

  <div class="mw-page">
    <div class="mw-head">
      <div class="section-eyebrow">— digital garden · the milky way —</div>
      <h1 class="mw-title">
        <span class="grad-text g-cosmic">A whole sky</span> of half-formed thoughts.
      </h1>
      <p class="mw-sub">
        {total} notes laid out along the band. {totalLinks} wiki-links between them. Bigger stars mean
        more backlinks. Hover any to read the title, click to open the note.
      </p>
    </div>

    <MilkyWay client:idle pages={pages} topics={topics} baseUrl={meta.baseUrl} />

    <section class="mw-recent">
      <div class="section-eyebrow">— recently watered —</div>
      <h2 class="mw-recent-title-row">The notes in motion this fortnight.</h2>
      <div class="mw-recent-list">
        {
          recent.map((n) => (
            <a
              class="mw-recent-row"
              href={`${meta.baseUrl}/${n.id}`}
              target="_blank"
              rel="noopener noreferrer"
            >
              <span class="mw-recent-date">{n.date}</span>
              <span class="mw-recent-title">{n.title}</span>
              <span class="mw-recent-meta">
                <span class="dot" style={`background:${topicColorById[n.topic] ?? '#fff'}`} />
                <span>{topicLabelById[n.topic] ?? n.topic}</span>
                <span class="magnitude" title="Magnitude — lower is brighter">
                  {formatMagnitude(noteMagnitude(n))}
                </span>
                <span class="muted">· {n.links.length} links</span>
              </span>
              <span class="mw-recent-arrow">→</span>
            </a>
          ))
        }
      </div>
    </section>
  </div>
</Base>
