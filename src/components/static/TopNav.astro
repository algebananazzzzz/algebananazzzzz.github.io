---
const { pathname } = Astro.url;
const isActive = (href: string) => (href === '/' ? pathname === '/' : pathname.startsWith(href));

const links = [
  { href: '/', label: 'Home', key: 'home' },
  { href: '/about', label: 'About', key: 'about' },
  { href: '/projects', label: 'Projects', key: 'projects' },
  { href: '/experience', label: 'Experience', key: 'experience' },
];
---

<header class="topnav" id="topnav" aria-label="Primary">
  <div class="topnav-inner">
    <a href="/" class="brand" aria-label="home">
      <img src="/assets/banana.png" alt="" width="22" height="22" aria-hidden="true" />
      <span>algebananazzzzz</span>
    </a>

    <nav class="nav-links" aria-label="primary">
      {
        links.map(({ href, label, key }) => (
          <a
            href={href}
            aria-current={isActive(href) ? 'page' : undefined}
            class:list={['nav-link', isActive(href) ? 'active' : '']}
            data-nav-key={key}
          >
            {label}
          </a>
        ))
      }
      <a
        href="/milky-way"
        class="milky-pill"
        aria-current={isActive('/milky-way') ? 'page' : undefined}
        aria-label="enter the milky way"
      >
        <span class="star" aria-hidden="true"></span>
        <span>Milky Way</span>
        <svg
          class="arrow"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path>
        </svg>
      </a>
    </nav>

    <div class="topnav-tools">
      <div
        class="meteor-counter zero"
        id="meteor-counter"
        title="Watch for shooting stars — click one to catch it"
        aria-label="Challenge: catch a meteor"
      >
        <svg
          class="ico"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.8"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M3 21 L13 11"></path>
          <path d="M14 4 L20 10"></path>
          <path d="M18 4 L21 7" opacity=".6"></path>
          <circle cx="13.5" cy="10.5" r="2.2" fill="currentColor" stroke="none"></circle>
        </svg>
        <span class="lbl">catch a meteor</span>
        <span class="num">0</span>
      </div>
    </div>
  </div>
</header>

<script>
  const nav = document.getElementById('topnav');
  const counter = document.getElementById('meteor-counter');
  if (nav) {
    const isHome = document.documentElement.dataset.home === 'true';

    if (!isHome) {
      // Non-home pages: nav is visible immediately, no scroll gate.
      nav.classList.add('is-visible');
    } else {
      // Home: reveal once we're past the splash (~80% of viewport).
      const update = () => {
        const y = window.scrollY || 0;
        nav.classList.toggle('is-visible', y > window.innerHeight * 0.8);
      };
      update();
      window.addEventListener('scroll', update, { passive: true });
      window.addEventListener('resize', update);
    }
  }

  if (counter) {
    const KEY = 'meteors-caught';
    const numEl = counter.querySelector('.num');
    const lblEl = counter.querySelector('.lbl');
    const read = () => {
      try {
        return parseInt(localStorage.getItem(KEY) ?? '0', 10) || 0;
      } catch {
        return 0;
      }
    };
    const render = (n: number) => {
      if (numEl) numEl.textContent = String(n);
      if (lblEl) lblEl.textContent = n === 0 ? 'catch a meteor' : 'meteors caught';
      counter.classList.toggle('zero', n === 0);
      counter.classList.toggle('have', n > 0);
    };
    render(read());
    window.addEventListener('meteor-caught', () => {
      const next = read() + 1;
      try {
        localStorage.setItem(KEY, String(next));
      } catch {}
      counter.classList.add('bump');
      setTimeout(() => counter.classList.remove('bump'), 900);
      render(next);
    });
  }
</script>

<style>
  /* ============================================================
     Top nav — reveal on scroll
     ============================================================ */
  .topnav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    height: 64px;
    display: flex;
    align-items: center;
    background: linear-gradient(to bottom, rgba(2, 3, 10, 0.55), rgba(2, 3, 10, 0.42));
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(148, 163, 184, 0.1);
    transform: translateY(-100%);
    opacity: 0;
    pointer-events: none;
    transition:
      transform 600ms cubic-bezier(0.32, 0.72, 0, 1),
      opacity 400ms ease-out;
  }

  .topnav.is-visible {
    transform: translateY(0);
    opacity: 1;
    pointer-events: auto;
  }

  .topnav-inner {
    max-width: 1280px;
    width: 100%;
    margin: 0 auto;
    padding: 0 var(--space-5);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-5);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    letter-spacing: -0.01em;
    color: #f1f5f9;
  }

  .brand img {
    width: 22px;
    height: 22px;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: var(--text-sm);
  }

  .nav-link {
    padding: 7px 12px;
    color: rgba(241, 245, 249, 0.62);
    border-radius: var(--radius-sm);
    letter-spacing: -0.005em;
    transition: color var(--dur-base);
  }

  .nav-link:hover {
    color: #f1f5f9;
  }

  .nav-link.active {
    color: #f1f5f9;
  }

  /* Milky Way pill — solid nebula gradient button */
  .milky-pill {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 7px 16px 7px 14px;
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 600;
    color: #ffffff;
    letter-spacing: 0.01em;
    position: relative;
    background: linear-gradient(
      110deg,
      #4338ca 0%,
      #7e22ce 28%,
      #be185d 56%,
      #6366f1 82%,
      #4338ca 100%
    );
    background-size: 250% 100%;
    background-position: 0% 50%;
    border: 1px solid rgba(255, 255, 255, 0.12);
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.04) inset,
      0 8px 24px -8px rgba(190, 24, 93, 0.45),
      0 4px 14px -4px rgba(79, 70, 229, 0.45);
    transition:
      background-position 5s ease,
      box-shadow var(--dur-base),
      transform var(--dur-base);
    animation: milkyShift 14s linear infinite;
    isolation: isolate;
  }

  .milky-pill::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 999px;
    background: radial-gradient(
        ellipse 60% 100% at 20% 50%,
        rgba(255, 255, 255, 0.2),
        transparent 60%
      ),
      radial-gradient(ellipse 50% 100% at 80% 50%, rgba(255, 230, 200, 0.15), transparent 60%);
    pointer-events: none;
    z-index: -1;
    mix-blend-mode: screen;
  }

  .milky-pill:hover {
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.1) inset,
      0 12px 30px -8px rgba(190, 24, 93, 0.65),
      0 6px 18px -4px rgba(79, 70, 229, 0.55);
  }

  .milky-pill .star {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #fff;
    box-shadow:
      0 0 8px #fff,
      0 0 16px rgba(255, 255, 255, 0.65);
  }

  .milky-pill .arrow {
    width: 14px;
    height: 14px;
    transition: transform var(--dur-base);
  }

  .milky-pill:hover .arrow {
    transform: translateX(3px);
  }

  @keyframes milkyShift {
    0% {
      background-position: 0% 50%;
    }

    100% {
      background-position: 250% 50%;
    }
  }

  /* Right-side tools cluster — meteor counter, soundscape, search */
  .topnav-tools {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  /* Catch-a-meteor counter — pulsing in zero state, settled when caught */
  .meteor-counter {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 5px 10px 5px 8px;
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    color: rgba(241, 245, 249, 0.78);
    background: rgba(15, 23, 42, 0.5);
    border: 1px solid rgba(148, 163, 184, 0.18);
    cursor: default;
    transition:
      color var(--dur-base),
      border-color var(--dur-base),
      background var(--dur-base),
      transform var(--dur-base);
  }

  .meteor-counter .ico {
    width: 13px;
    height: 13px;
    color: rgba(244, 114, 182, 0.9);
    transform: rotate(-8deg);
  }

  .meteor-counter .num {
    font-variant-numeric: tabular-nums;
    color: #fff;
    font-weight: 600;
    padding: 1px 6px;
    border-radius: 999px;
    background: rgba(244, 114, 182, 0.18);
    border: 1px solid rgba(244, 114, 182, 0.35);
    min-width: 18px;
    text-align: center;
  }

  .meteor-counter.zero {
    color: rgba(241, 245, 249, 0.7);
    animation: mc-breathe 2.6s ease-in-out infinite;
  }

  .meteor-counter.zero .num {
    background: rgba(148, 163, 184, 0.1);
    border-color: rgba(148, 163, 184, 0.25);
    color: rgba(241, 245, 249, 0.7);
  }

  .meteor-counter.zero .ico {
    animation: mc-icoTilt 2.6s ease-in-out infinite;
  }

  .meteor-counter:hover {
    color: #f1f5f9;
    border-color: rgba(244, 114, 182, 0.5);
  }

  .meteor-counter.bump {
    transform: scale(1.06);
    border-color: rgba(244, 114, 182, 0.8);
  }

  @keyframes mc-breathe {
    0%,
    100% {
      box-shadow: 0 0 0 0 rgba(244, 114, 182, 0);
    }

    50% {
      box-shadow: 0 0 0 6px rgba(244, 114, 182, 0.12);
    }
  }

  @keyframes mc-icoTilt {
    0%,
    100% {
      transform: rotate(-8deg) translateX(0);
    }

    50% {
      transform: rotate(-22deg) translateX(-2px);
    }
  }

  /* Mobile */
  @media (max-width: 980px) {
    /* Tools row: collapse labels into icons to keep navbar uncluttered */
    .meteor-counter .lbl {
      display: none;
    }

    /* Hide the desktop nav links — only show brand + Milky Way pill */
    .nav-links .nav-link {
      display: none;
    }

    .nav-links {
      gap: 8px;
    }
  }

  @media (max-width: 720px) {
    .topnav {
      height: 56px;
    }

    .topnav-inner {
      padding: 0 var(--space-3);
      gap: 8px;
    }

    .brand span {
      display: none;
    }

    /* Hide the text nav links — keep the Milky Way pill as the sole CTA,
       and let users reach other pages via search or the home page. */
    .nav-link {
      display: none;
    }

    .milky-pill {
      padding: 6px 13px 6px 12px;
      font-size: 12px;
      gap: 7px;
    }

    .milky-pill .arrow {
      width: 12px;
      height: 12px;
    }

    /* Meteor counter loses the icon label on mobile — keep it compact */
    .meteor-counter {
      padding: 4px 8px 4px 6px;
      font-size: 10px;
      gap: 5px;
    }

    .topnav-tools {
      gap: 6px;
    }
  }

  @media (max-width: 420px) {
    .milky-pill {
      padding: 6px 11px;
      font-size: 11px;
      gap: 6px;
    }
  }
</style>
