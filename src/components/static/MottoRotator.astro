---
import manifest from '@/content/wiki-manifest.json';
import type { WikiManifest } from '@/types/wiki';

const wiki = manifest as WikiManifest;
const baseUrl = wiki.meta.baseUrl;
const mottos = wiki.mottos.map((m) => ({ text: m.text, href: `${baseUrl}/${m.pageId}` }));
const initial = mottos[0];
---

<a
  class="hero-motto"
  id="hero-motto"
  href={initial.href}
  target="_blank"
  rel="noopener noreferrer"
  data-mottos={JSON.stringify(mottos)}
>
  &ldquo;{initial.text}&rdquo;
</a>

<script>
  const el = document.getElementById('hero-motto') as HTMLAnchorElement | null;
  if (el) {
    const mottos: { text: string; href: string }[] = JSON.parse(el.dataset.mottos || '[]');
    if (mottos.length > 1) {
      let idx = 0;

      const DISPLAY = 12000;
      const FADE = 2000;

      const cycle = () => {
        el.classList.add('fade-out');
        setTimeout(() => {
          idx = (idx + 1) % mottos.length;
          el.textContent = `\u201C${mottos[idx].text}\u201D`;
          el.href = mottos[idx].href;
          el.classList.remove('fade-out');
        }, FADE);
      };

      setInterval(cycle, DISPLAY);
    }
  }
</script>
